+############### NEW ########################################
+import os
+import re
+
+# 「language 言語名 <asr_text>」を全文から綺麗に消し去るための正規表現
+_QWEN_ASR_PREFIX_RE = re.compile(r"language\s+[\w\-]+\s*<asr_text>\s*", re.IGNORECASE)
+
+def _strip_qwen_asr_prefix(s: str) -> str:
+    if not s:
+        return s
+    # 複数結合されたすべてのプレフィックスを一括で削除
+    return _QWEN_ASR_PREFIX_RE.sub("", s)
+############################################################
+
