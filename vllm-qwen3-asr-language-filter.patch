+############### NEW ########################################
+import re
+
+# Qwen3-ASR は
+#   language Japanese<asr_text>...
+#   language Chinese<asr_text>...
+# のようなブロックを連結して返すことがある．
+# 日本語・英語以外のブロックは丸ごと除去する．
+
+_QWEN_ASR_BLOCK_RE = re.compile(
+    r"language\s+([A-Za-z][A-Za-z0-9_-]*)\s*<asr_text>\s*",
+    re.IGNORECASE,
+)
+
+_QWEN_ALLOWED_LANGS = {
+    "japanese",
+    "english",
+}
+
+def _filter_qwen_asr(text: str) -> str:
+    if not text:
+        return text
+
+    matches = list(_QWEN_ASR_BLOCK_RE.finditer(text))
+
+    # Qwen3-ASR形式でなければ何もしない
+    if not matches:
+        return text
+
+    parts = []
+
+    for i, m in enumerate(matches):
+        lang = m.group(1).lower()
+
+        start = m.end()
+        end = matches[i + 1].start() if i + 1 < len(matches) else len(text)
+
+        if lang in _QWEN_ALLOWED_LANGS:
+            parts.append(text[start:end])
+
+    return "".join(parts)
+############################################################
+
